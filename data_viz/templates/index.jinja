<!doctype html>
<html lang="en">

<head>
    <title>Illicit Substance Dash | Internal Use</title>
    <!-- Required meta tags -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <!-- Bootstrap CSS v5.2.1 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
</head>

<body class="overflow-x-hidden">
    <div id="page-container" class="d-flex flex-row">
        <div id="sidebar-nav" class="d-flex flex-column flex-shrink-0 p-3 text-white bg-dark"
            style="width: 250px; height: 100vh;">
            <p hx-get="/introduction/htmx" hx-trigger="click" hx-target="#content-div" hx-swap="innerHTML swap:1s settle:1s"
                class="d-flex mb-3 mb-md-0 me-md-auto text-white text-decoration-none htmx-element" hx-push-url="/">
                Canadian Drug Toxicity Surveillance
            </p>
            <hr>
            <div class="accordion accordion-flush bg-success" id="accordionFlushMenu">
                <div class="accordion-item bg-dark text-light">
                    <h2 class="accordion-header" id="flush-headingOne">
                        <button class="accordion-button bg-dark text-light collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#flush-collapseOne" aria-expanded="true"
                            aria-controls="flush-collapseOne">
                            National Trends
                        </button>
                    </h2>
                    <div id="flush-collapseOne" class="accordion-collapse collapse" aria-labelledby="flush-headingOne"
                        data-bs-parent="#accordionFlushMenu">
                        <div class="accordion-body bg-transparent">
                            <p hx-get="/toxicity-deaths/htmx" hx-trigger="click" hx-target="#content-div"
                                hx-swap="innerHTML swap:1s settle:1s" hx-push-url="/toxicity-deaths"
                                class="nav-link text-white htmx-element accordion-" aria-current="page">
                                Total Toxicity Deaths
                            </p>
                        </div>
                    </div>
                </div>
                <div class="accordion-item bg-dark text-light">
                    <h2 class="accordion-header" id="flush-headingOne">
                        <button class="accordion-button bg-dark text-light collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#flush-collapseProvinces" aria-expanded="true"
                            aria-controls="flush-collapseProvinces">
                            Provincial Trends
                        </button>
                    </h2>
                    <div id="flush-collapseProvinces" class="accordion-collapse collapse"
                        aria-labelledby="flush-headingOne" data-bs-parent="#accordionFlushMenu">
                        <div class="accordion-body bg-transparent">
                            <p hx-get="/province/british-columbia/htmx" hx-trigger="click" hx-target="#content-div"
                                hx-swap="innerHTML swap:1s settle:1s" hx-push-url="/province/british-columbia"
                                class="nav-link text-white htmx-element accordion-" aria-current="page">
                                British Columbia
                            </p>
                            <p hx-get="/province/alberta/htmx" hx-trigger="click" hx-target="#content-div"
                                hx-swap="innerHTML swap:1s settle:1s" hx-push-url="/province/alberta"
                                class="nav-link text-white htmx-element accordion-" aria-current="page">
                                Alberta
                            </p>
                            <p hx-get="/province/saskatchewan/htmx" hx-trigger="click" hx-target="#content-div"
                                hx-swap="innerHTML swap:1s settle:1s" hx-push-url="/province/saskatchewan"
                                class="nav-link text-white htmx-element accordion-" aria-current="page">
                                Saskatchewan
                            </p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        <div id="content-div" class="flex-column container fade-me-out fade-me-in blue">
            <!-- If we don't have a province var, then we just render the intro template here -->
            {% if province=="british-columbia" %}
            {% include 'provincial_bc.jinja' %}
            {% elif province=="saskatchewan" %}
            {% include 'provincial_sask.jinja' %}
            {% elif province=="alberta" %}
            {% include 'no_data.jinja' %}
            {% else %}
            {% include 'introduction.jinja' %}
            {% endif %}
            <!-- Content within this div will get swapped out with HTMX on click of nav buttons -->
            <!-- To begin, it will have a sort of "about us" page with some instructions and content -->
            {% if dash_template %}
            {% include dash_template %}
            {% else %}
            {% include 'introduction.jinja' %}
            {% endif %}
        </div>
    </div>
    <footer>
        <!-- place footer here -->
    </footer>
    <!-- Bootstrap JavaScript Libraries -->
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
        integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
        crossorigin="anonymous"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"
        integrity="sha384-BBtl+eGJRgqQAUMxJ7pMwbEyER4l1g+O15P+16Ep7Q9Q+zqX6gSbd85u4mG4QzX+"
        crossorigin="anonymous"></script>

    <!-- import js and css -->
    {% assets "js_all" %}
    <script type="text/javascript" src="{{ ASSET_URL }}"></script>
    {% endassets %}
    {% assets "css_all" %}
    <link rel="stylesheet" href="{{ ASSET_URL }}">
    {% endassets %}
</body>

</html>