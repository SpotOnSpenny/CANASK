<!doctype html>
<html lang="en">

<head>
    <title>Illicit Substance Dash | Mockup</title>
    <!-- Required meta tags -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

    <!-- Bootstrap CSS v5.2.1 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
</head>

<body>
    <div id="page-container" class="d-flex flex-row">
        <div id="sidebar-nav" class="d-flex flex-column flex-shrink-0 p-3 text-white bg-dark"
            style="width: 250px; height: 100%;">
            <p hx-get="/introduction" hx-trigger="click" hx-target="#content-div" hx-swap="innerHTML swap:1s settle:1s"
                class="d-flex mb-3 mb-md-0 me-md-auto text-white text-decoration-none htmx-element">
                Canadian Drug Toxicity Surveillance
            </p>
            <hr>
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <p hx-get="/toxicity-deaths" hx-trigger="click" hx-target="#content-div"
                        hx-swap="innerHTML swap:1s settle:1s" class="nav-link text-white htmx-element"
                        aria-current="page">
                        Total Toxicity Deaths
                    </p>
                </li>
                <li class="nav-item">
                    <p hx-get="/no-data" hx-trigger="click" hx-target="#content-div"
                        hx-swap="innerHTML swap:1s settle:1s" class="nav-link text-white htmx-element"
                        aria-current="page">
                        Toxicity Deaths by Type of Drug
                    </p>
                </li>
                <li class="nav-item">
                    <p hx-get="/no-data" hx-trigger="click" hx-target="#content-div"
                        hx-swap="innerHTML swap:1s settle:1s" class="nav-link text-white htmx-element"
                        aria-current="page">
                        Toxicity Deaths by Demographics
                    </p>
                </li>
                <li class="nav-item">
                    <p hx-get="/toxicity-deaths" hx-trigger="click" hx-target="#content-div"
                        hx-swap="innerHTML swap:1s settle:1s" class="nav-link text-white htmx-element"
                        aria-current="page">
                        Toxicity Deaths by Region
                    </p>
                </li>
                <li class="nav-item">
                    <p hx-get="/no-data" hx-trigger="click" hx-target="#content-div"
                        hx-swap="innerHTML swap:1s settle:1s" class="nav-link text-white htmx-element"
                        aria-current="page">
                        Drug Supply by Region
                    </p>
                </li>
                <li class="nav-item">
                    <p hx-get="/no-data" hx-trigger="click" hx-target="#content-div"
                        hx-swap="innerHTML swap:1s settle:1s" class="nav-link text-white htmx-element"
                        aria-current="page">
                        Hospitalizations Related to Drug Toxicity
                    </p>
                </li>
                <li class="nav-item">
                    <p hx-get="/no-data" hx-trigger="click" hx-target="#content-div"
                        hx-swap="innerHTML swap:1s settle:1s" class="nav-link text-white htmx-element"
                        aria-current="page">
                        Naloxone Distribution and Usage
                    </p>
                </li>
            </ul>
        </div>
        <div id="content-div" class="flex-column container fade-me-out fade-me-in blue">
            <!-- Content within this div will get swapped out with HTMX on click of nav buttons -->
            <!-- To begin, it will have a sort of "about us" page with some instructions and content -->
            <div class="p-5 w-100 h-100 d-flex justify-content-center align-items-center">
                <div class="card">
                    <div class="card-body text-center">
                        <h4 class="card-title">Welcome to the Canadian Drug Toxicity Surveillance System</h4>
                        <p class="card-text">The aim of this application is to provide a comprehensive overview of
                            up-to-date
                            statistics related to the Canadian drug crisis in a single application tailored to the
                            unique needs of
                            the different stakeholders who require it. In doing so, we hope to enable those who use
                            drugs,
                            physicians, and policy makers to
                            make informed decisions using the most current data and meaningful trends regarding the
                            Opioid overdose
                            epidemic within Canada in its current state.</p>
                        <br />
                        <p class="card-text">Please use the navigation bar on the left to explore the different sections
                            of the tool
                            that may be of interest to you.</p>

                        <div class="container">
                            <div class="row justify-content-center align-items-center g-2">
                                <div class="col">
                                    <img src="/static/assets/images/CHI.jpeg" class="img-fluid rounded-top logos"
                                        alt="University of Calgary Centre for Health Informatics Logo" />
                                </div>
                                <div class="col">
                                    <img src="/static/assets/images/UCalgary-horizontal-logo_2.webp"
                                        class="img-fluid rounded-top logos" alt="University of Calgary" />
                                </div>
                                <div class="col">Other logos...</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer>
        <!-- place footer here -->
    </footer>
    <!-- Bootstrap JavaScript Libraries -->
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
        integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
        crossorigin="anonymous"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"
        integrity="sha384-BBtl+eGJRgqQAUMxJ7pMwbEyER4l1g+O15P+16Ep7Q9Q+zqX6gSbd85u4mG4QzX+"
        crossorigin="anonymous"></script>

    <!-- import js and css -->
    {% assets "js_all" %}
    <script type="text/javascript" src="{{ ASSET_URL }}"></script>
    {% endassets %}
    {% assets "css_all" %}
    <link rel="stylesheet" href="{{ ASSET_URL }}">
    {% endassets %}
</body>

</html>