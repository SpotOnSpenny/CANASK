<div class="position-absolute top-0 start-0 w-100 h-100">
    <div class="top-0 w-50 mx-auto pt-3">
        {% with messages = get_flashed_messages(with_categories=true) %}
            {% if messages %}
                {% for category, message in messages %}
                <div class="alert alert-{{ category }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                {% endfor %}
            {% endif %}
        {% endwith %}
    </div>
</div>

<div id="page-container" class="fade-me-out fade-me-in d-flex justify-content-center align-items-center vh-100">
    <div class="d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow-sm" style="width: 24rem;">
            <div class="card-body p-4">
            <h3 class="card-title mb-3 text-center">CANASK Login</h3>
            <p class="text-center">CANASK is currently in a closed beta while it is being developed. If you have a data source you think should be included, or would like to access the tool and provide feedback, please reach out to us at <a href="mailto:spencer.fietz@ucalgary.ca">spencer.fietz@ucalgary.ca</a>.</p>
            <!-- HTMX Login Form -->
            <form
                hx-post="/v1/login"
                hx-target="#page-container"
                hx-swap="innerHTML swap:1s settle:1s" 
                hx-push-url="/"
                class="needs-validation"
                novalidate
            >
                <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input
                    type="text"
                    name="username"
                    id="username"
                    class="form-control"
                    required
                    autofocus
                >
                <div class="invalid-feedback">
                    Please enter your username.
                </div>
                </div>

                <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input
                    type="password"
                    name="password"
                    id="password"
                    class="form-control"
                    required
                >
                <div class="invalid-feedback">
                    Please enter your password.
                </div>
                </div>

                <button type="submit" class="btn btn-primary w-100">Log In</button>

                <!-- This will show an error banner if login fails -->
                <div id="error-container" class="mt-3"></div>
            </form>
            </div>
        </div>
    </div>
</div>

<!-- Also swap the title -->
<title hx-swap-oob="true">CANASK | Login</title>