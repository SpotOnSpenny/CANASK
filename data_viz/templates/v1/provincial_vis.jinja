<div class="container h-100 mobile-height-adjust py-2">
    <!-- This is the top row of the page -->
    <div class="row justify-content-center align-items-center py-2 mb-2 g-2 menu-row">
        <!-- This is the navigation bar for the different categories of visualizations -->
        <div class="col-md-8 mobile-height h-100">
            <div class="card h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center h-100">
                    <h4 class="card-title">Visualizations</h4>
                                        <nav class="nav nav-pills flex-row justify-content-center">
                        <li class="nav-item dropdown">
                            <a href="" role="button" data-bs-toggle="dropdown" id="drugSupplyDropdown"
                                class="nav-link dropdown-toggle">Drug Supply</a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item active" onclick="changeChartBC(this, 'drugSupplyDropdown')"
                                        id="drugs-by-category" aria-current="page">Drugs by
                                        Category</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" id="fent-and-benzos"
                                        onclick="changeChartBC(this, 'drugSupplyDropdown')" aria-current="page">Presence
                                        of
                                        Fentanyl and Benzodiazepines</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" onclick="changeChartBC(this, 'drugSupplyDropdown')"
                                        id="types-of-opioids" aria-current="page">Opioids by
                                        Type</a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fs-6 p-2 active" href="" role="button" data-bs-toggle="dropdown"
                                id="deathsDropdown">Deaths and Demographics</a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" onclick="changeChartBC(this, 'deathsDropdown')"
                                        id="deaths-by-drug" aria-current="page">Drug Toxicity Deaths by Type of
                                        Drug</a>
                                </li>
                            </ul>
                        </li>
                        <a class="nav-link disabled fs-6 p-2" href="#">Naloxone</a>
                        <a class="nav-link disabled fs-6 p-2" href="#">Safe Consumption and Drug Checking Sites</a>
                        <a class="nav-link disabled fs-6 p-2" href="#">Miscellaneous</a>
                    </nav>
                </div>
            </div>
        </div>
        <!-- This is the P.A.S.S. score card that shows the current score -->
        <div class="col-md-4 h-100">
            <div class="card h-100 pass-card">
                <div class="card-body h-100">
                    <div class="h-100 text-center d-flex justify-content-center flex-column">
                        <h5 class="pass-title card-title">P.A.S.S. Score</h5>
                        <p class="pass-score">50%</p>
                        <div class="d-block w-100">
                            <div class="progress">
                                <div class="progress-bar bg-warning" role="progressbar" style="width: 50%;"
                                    aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                        <div class="flex align-items-center">
                            <p class="card-text d-flex justify-content-center align-items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="pe-2" width="20" height="20"
                                    fill="currentColor" class="bi bi-info-circle-fill" viewBox="0 0 16 16">
                                    <path
                                        d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2" />
                                </svg>
                                Click to learn more about P.A.S.S.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- This is the main content area where the visualizations will be rendered -->
    <div class="row data-row pb-2">
        <div class="col-md h-100">
            <div class="card h-100">
                <div class="card-body text-center h-100 d-flex align-items-center justify-content-center" id="viz-card">
                    <!-- Overlayed controls -->
                    <div class="position-absolute top-0 start-0 m-1 z-3" style="">
                        <div id="count-rate-toggle" class="d-none btn-group mb-2 align-items-start" role="group" aria-label="Basic radio toggle button group">
                            <input type="radio" class="btn-check" name="data-toggle" id="counts-toggle"
                                autocomplete="off" checked>
                            <label class="btn btn-outline-primary" for="counts-toggle">Counts</label>
                            <input type="radio" class="btn-check" name="data-toggle" id="rates-toggle"
                                autocomplete="off">
                            <label class="btn btn-outline-primary" for="rates-toggle">Rates</label>
                        </div>
                        <div class="d-flex flex-column gap-2 align-items-start">
                            <button type="button" class="btn btn-secondary d-none" id="back-button"
                                onclick="resetVisual()" title="Back to Visualizations">
                                <i class="bi bi-arrow-left"></i>
                            </button>
                            <button type="button" class="btn btn-secondary d-none" id="restart-button"
                                onclick="resetVisual()" title="Restart">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                        </div>  
                    </div>
                    <!-- This is the div where the visualizations will be rendered -->
                    <div id="vis-div" class="">
                        <div class="spinner-border" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- This is the data table that will be rendered below the visualizations -->
    <div class="row  justify-content-center align-items-center pb-3">
        <div class="col">
            <div class="card pe-3">
                <div class="card-body overflow-scroll">
                    <h4 class="card-title" id="table-title"></h4>
                    <div id="data-table" class="text-center">
                        <div id="toxicity-deaths-vis" class="spinner-border" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- This is the row that contains the about this data section -->
    <div class="row justify-content-center align-items-center pb-2">
        <div class="col-md h-100">
            <div class="card h-100 overflow-y-scroll">
                <div class="card-body h-100">
                    <div id="about-data" class="h-100">
                        <div class="data-spinner-div h-100 d-flex align-items-center justify-content-center">
                            <div id="toxicity-deaths-vis" class="spinner-border" role="status"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', async function () {
            let province = "{{province}}";
            let currentVisual = "drug_death_heatmap";
            await fetchRegionData(province);
            await createVisualMap(province, currentVisual, currentGeojson, currentData["drug_death_heatmap"]["data"]["counts"], currentData["drug_death_heatmap"]["data_source"], null)
        });
    </script>
</div>